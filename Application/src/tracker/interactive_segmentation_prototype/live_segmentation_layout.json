{
    "objects":[
        {
            "type":"text",
            "text":"Hello World! {frame} {2bowl:{mouse}}",
            "color":[255,255,255]
        },
        

        {
            "type":"circle",
            "radius": 10,
            "fill":[255,0,0,125],
            "origin":[0.5,0.5],
            "pos": "{2hud:[0,0]}"
        },
        {
            "type":"circle",
            "radius": 10,
            "fill":[255,0,0,125],
            "origin":[0.5,0.5],
            "pos": "{2hud:{video_size}}"
        },
        {
            "type":"button",
            "action":"set_frame:0",
            "text":"reset",
            "pos":[100,100]
        },
        {
            "type":"each",
            "var":"{merge:{for:i:{range:0:{video_size.w}:500}:{for:j:{range:0:{video_size.h}:500}:[{i},{j}]}}}",
            "do": {
                "type":"circle",
                "radius": 3,
                "origin":[0.5,0.5],
                "fill":[255,255,0],
                "pos": "{2hud:{i}}"
            }
        },

        {
            "type": "each",
            "var": "{data}",
            "do": {
                "type": "text",
                "text": "{index}: {i} {2hud:[{i.x},{i.y}]} {size2hud:[{i.w},{i.h}]}",
                "color": [255, 255, 255],
                "pos": "[50,{+:100:{*:{index}:20}}]",
                "font":{"size":0.5}
            }
        },

        {
            "type": "each",
            "var": "{data}",
            "do": {
                "type": "collection",
                "pos":"{2hud:[{i.x},{i.y}]}",
                "children": [
                    {
                        "type":"image_generator",
                        "generator":"blob_image",
                        "parm":"{index}", 
                        "scale":"{size2hud:[1,1]}",
                        "color":[255,0,0,125]
                    },
                    {
                        "type":"rect",
                        "size":"{size2hud:[{i.w},{i.h}]}",
                        "line":[200,200,200,255]
                    },
                    {
                        "type":"label",
                        "text":"<c><key>{index}</key>: [<nr>{i.x}</nr>,<nr>{i.y}</nr>] <nr>{round:{*:100:{i.conf}}:0}</nr>%</c>",
                        "length":25,
                        "color":[200,200,200,255],
                        "line":[200,200,200,255],
                        "fill":[50,50,50,150],
                        "center":[0,0],
                        "size":"{size2hud:[{i.w},{i.h}]}",
                        "font":{"size":0.35,"align":"middle"}
                    }
                ]
            }
        },

        {
            "type":"settings",
            "var":"",
            "pos":"[10,{-:{window_size.y}:20}]",
            "size":"[{max:100:{-:{window_size.x}:20}},30]",
            "origin":[0,1],
            "fill":[30,30,30,255],
            "cleartext":"<sym>⮾</sym>",
            "label":{
                "size":[500,30],
                "line":[200,0,0,255],
                "color":[255,255,255] 
            },
            "list":{
                "size":[300,100]
            }
        }
    ]
}