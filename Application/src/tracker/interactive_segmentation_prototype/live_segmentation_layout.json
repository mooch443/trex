{
    "defaults":{
        "vars":{
            "mouse_in_bowl": "{2bowl:{mouse}}"
        }
    },
    "objects":[
        {
            "type":"hlayout",
            "pad":[5,5,5,5],
            "children":[
                {
                    "type":"stext",
                    "text":"<c>SAM3</c> @ frame {if:{nequal:{frame_requested}:null}:<sym>⏳</sym> <red>{frame_requested}</red>:<nr>{frame}</nr>}",
                    "color":[255,255,255]
                },
                {
                    "type":"stext",
                    "text":"<h5><sym>🖰</sym></h5> <i>{round:{mouse_in_bowl.x}},{round:{mouse_in_bowl.y}}</i>",
                    "font":{"size":0.5},
                    "color":"{if:{&&:{>=:{mouse_in_bowl.x}:0}:{<:{mouse_in_bowl.x}:{video_size.w}}:{>=:{mouse_in_bowl.y}:0}:{<:{mouse_in_bowl.y}:{video_size.h}}}:[255,255,255,255]:[200,120,80,100]}"
                }
            ]
        },
        
        {
            "type":"circle",
            "radius": 10,
            "fill":[255,0,0,125],
            "origin":[0.5,0.5],
            "pos": "{2hud:[0,0]}"
        },
        {
            "type":"circle",
            "radius": 10,
            "fill":[255,0,0,125],
            "origin":[0.5,0.5],
            "pos": "{2hud:{video_size}}"
        },
        {
            "type":"hlayout",
            "pos":[10,50],
            "children":[
                {
                    "type":"button",
                    "action":"set_frame:{global.gui_frame}", 
                    "text":"<sym>⮎</sym> go to",
                    "size":[100,30],
                    "corners": ["left"],
                    "font":{"size":0.6,"align":"center"},
                    "fill":"{if:{||:{selected}:{hovered}}:[60,60,60,200]:[50,50,50,200]}",
                    "line":"{if:{||:{selected}:{hovered}}:[100,175,250,200]:[100,100,100,50]}"
                },
                {
                    "type":"settings",
                    "var":"gui_frame",
                    "cleartext":"<sym>⮾</sym>",
                    "size":[50,30],
                    "corners": ["right"],
                    "desc":"",
                    "font":{"size":0.6,"align":"center"},
                    "fill":"{if:{||:{selected}:{hovered}}:[50,50,50,200]:[30,30,30,200]}",
                    "line":"{if:{||:{selected}:{hovered}}:[100,175,250,200]:[100,100,100,50]}",
                    "list":{
                        "line":[220,220,220,200],
                        "fill":[25,25,25,220],
                        "size":[700,300],
                        "font":{"size":0.6}
                    }
                },
                {
                    "type":"rect",
                    "size":[5,30],
                    "fill":[0,0,0,0]
                },
                {
                    "type":"settings",
                    "var":"detect_sam3_prompt",
                    "cleartext":"<sym>⮾</sym>",
                    "size":"[{max:100:{-:{window_size.x}:175}},30]",
                    "desc":"",
                    "corners": ["all"],
                    "label":{
                        "corners": ["all"]
                    },
                    "font":{"size":0.6,"align":"center"},
                    "fill":"{if:{||:{selected}:{hovered}}:[60,60,60,200]:[50,50,50,200]}",
                    "line":"{if:{||:{selected}:{hovered}}:[100,175,250,200]:[100,100,100,50]}",
                    "list":{
                        "corners": ["all"],
                        "line":[220,220,220,200],
                        "fill":[25,25,25,220],
                        "size":[700,300],
                        "font":{"size":0.6}
                    }
                }
            ]
        },
        {
            "type":"each",
            "var":"{merge:{for:i:{range:0:{video_size.w}:500}:{for:j:{range:0:{video_size.h}:500}:[{i},{j}]}}}",
            "do": {
                "type":"circle",
                "radius": 3,
                "origin":[0.5,0.5],
                "fill":[255,255,0],
                "pos": "{2hud:{i}}"
            }
        },

        {
            "type": "each",
            "var": "{data}",
            "do": {
                "type": "text",
                "text": "{index}: {i} {2hud:[{i.x},{i.y}]} {size2hud:[{i.w},{i.h}]}",
                "color": [255, 255, 255],
                "pos": "[50,{+:100:{*:{index}:20}}]",
                "font":{"size":0.5}
            }
        },

        {
            "type": "each",
            "var": "{annotations}",
            "do": {
                "type":"collection",
                "children":[
                    {
                        "type": "rect",
                        "line": [255,0,0],
                        "fill":[255,0,0, 25],
                        "pos":"{2hud:[{i.x},{i.y}]}",
                        "size":"{size2hud:[{i.w},{i.h}]}"
                    },

                    {
                        "type":"stext",
                        "text":"<sym>🖰</sym> {index}",
                        "color":[255,0,0,255],
                        "origin":[0,0],
                        "font":{"size":0.3},
                        "pos":"{2hud:[{+:{i.x}:15},{+:{i.y}:10}]}"
                    },

                    {
                        "type":"label",
                        "text":"[{int:{i.x}},{int:{i.y}} {int:{i.w}}x{int:{i.h}}]",
                        "length":120,
                        "color":[255,0,0],
                        "font":{"size":0.4},
                        "line":[255,0,0,100],
                        "center":"{2hud:[{+:{i.x}:{*:0.5:{i.w}}},{+:{i.y}:{*:0.5:{i.h}}}]}"
                    },

                    {
                        "type":"button",
                        "action":"remove_annotation:{i.id}",
                        "text":"<sym>⮾</sym>",
                        "size":[18,18],
                        "origin":[1,0],
                        "color":"{if:{||:{selected}:{hovered}}:[255,255,255,255]:[255,0,0,150]}",
                        "font":{"size":0.7,"align":"center"},
                        "pos":"{2hud:[{-:{+:{i.x}:{i.w}}:5},{i.y}]}",
                        "fill":[1,0,0,0],
                        "line":[1,0,0,0]
                    }
                ]
            }
        },

        {
            "type": "each",
            "var": "{data}",
            "do": {
                "type": "collection",
                "pos":"{2hud:[{i.x},{i.y}]}",
                "children": [
                    {
                        "type":"image_generator",
                        "generator":"blob_image",
                        "parm":"{index}", 
                        "scale":"{size2hud:[1,1]}",
                        "color":[255,0,0,125]
                    },
                    {
                        "type":"rect",
                        "size":"{size2hud:[{i.w},{i.h}]}",
                        "line":[200,200,200,255]
                    },
                    {
                        "type":"label",
                        "text":"<c><key>{index}</key>: [<nr>{i.x}</nr>,<nr>{i.y}</nr>] <nr>{round:{*:100:{i.conf}}:0}</nr>%</c>",
                        "length":25,
                        "color":[200,200,200,255],
                        "line":[200,200,200,255],
                        "fill":[50,50,50,150],
                        "center":[0,0],
                        "size":"{size2hud:[{i.w},{i.h}]}",
                        "font":{"size":0.35,"align":"middle"}
                    }
                ]
            }
        },

        {
            "type":"settings",
            "var":"",
            "pos":"[10,{-:{window_size.y}:20}]",
            "size":"[{max:100:{-:{window_size.x}:30}},30]",
            "origin":[0,1],
            "fill":[30,30,30,255],
            "cleartext":"<sym>⮾</sym>",
            "label":{
                "size":[300,30],
                "line":[200,0,0,255],
                "color":[255,255,255] 
            },
            "list":{
                "size":[300,100]
            }
        }
    ]
}
